  "hazard_rules": [
    {
      "id": "H-WATERWALL-001",
      "var": "waterwall_temp",
      "threshold": 475.0,
      "direction": "upper",
      "margin_col": "hazard_waterwall_margin"
    },
    {
      "id": "H-PRESSURE-001",
      "var": "main_steam_pressure",
      "threshold": 28.3,
      "direction": "upper",
      "margin_col": "hazard_pressure_margin"
    },
    {
      "id": "H-FEEDWATER-001",
      "var": "feedwater_flow",
      "threshold": 184.8,
      "direction": "lower",
      "margin_col": "hazard_feedwater_margin"
    }
  ],
  "alarm_rules": [
    {
      "id": "A-BOILER-CUT",
      "kind": "deviation",
      "expr": "|steam_setpoint - main_steam_pressure| > BOILER_CUT_TH",
      "var": "main_steam_pressure",
      "setpoint_var": "steam_setpoint",
      "threshold": 1.5,
      "margin_col": "alarm_boiler_cut_margin"
    },
    {
      "id": "A-FUEL-CUT",
      "kind": "deviation",
      "expr": "|coal_flow - fuel_command| > FUEL_CUT_TH",
      "var": "coal_flow",
      "setpoint_var": "fuel_command",
      "threshold": 43.0,
      "margin_col": "alarm_fuel_cut_margin"
    },
    {
      "id": "A-WATER-CUT",
      "kind": "deviation",
